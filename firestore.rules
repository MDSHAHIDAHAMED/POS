rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function hasRole(role) { return isSignedIn() && getUserData().role == role; }
    function isAdmin() { return hasRole('admin') || hasRole('super_admin'); }
    function isStaff() { return isSignedIn() && getUserData().role in ['admin', 'super_admin', 'manager', 'cashier', 'accountant', 'store_keeper']; }

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || hasRole('manager') || hasRole('store_keeper');
    }

    match /sales/{saleId} {
      allow read: if isSignedIn();
      allow create: if isStaff();
      allow update: if isAdmin();
    }

    match /sales/{saleId}/items/{itemId} {
      allow read: if isSignedIn();
      allow create: if isStaff();
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || hasRole('manager');
    }

    match /brands/{brandId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || hasRole('manager');
    }

    match /suppliers/{supplierId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || hasRole('manager');
    }

    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /inventory_logs/{logId} {
      allow read: if isStaff();
      allow create: if isStaff();
    }
  }
}
