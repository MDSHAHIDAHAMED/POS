// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// USER & RBAC (Role Based Access Control)
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String?
  phone         String?
  avatarUrl     String?
  status        UserStatus @default(ACTIVE)
  
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft Delete

  sales         Sale[]    @relation("CashierSales")
  purchases     Purchase[]
  auditLogs     AuditLog[]
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // Super Admin, Admin, Manager, Cashier, etc.
  description String?
  
  users       User[]
  permissions Permission[] @relation("RolePermissions")
}

model Permission {
  id          String   @id @default(uuid())
  action      String   @unique // e.g., "create:product", "view:sales"
  description String?
  
  roles       Role[]   @relation("RolePermissions")
}

// -----------------------------------------------------------------------------
// CATALOG & PRODUCTS
// -----------------------------------------------------------------------------

model Product {
  id             String    @id @default(uuid())
  name           String
  sku            String    @unique
  barcode        String?   @unique
  description    String?
  
  purchasePrice  Decimal   @db.Decimal(10, 2)
  salePrice      Decimal   @db.Decimal(10, 2)
  wholesalePrice Decimal?  @db.Decimal(10, 2)
  taxRate        Decimal   @default(0) @db.Decimal(5, 2)
  discount       Decimal   @default(0) @db.Decimal(10, 2)
  
  imageUrl       String?
  status         ProductStatus @default(ACTIVE)

  categoryId     String
  category       Category  @relation(fields: [categoryId], references: [id])
  
  brandId        String?
  brand          Brand?    @relation(fields: [brandId], references: [id])

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime? // Soft delete

  inventories    Inventory[]
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

model Category {
  id          String    @id @default(uuid())
  name        String
  parentId    String?
  parent      Category? @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  
  products    Product[]
}

model Brand {
  id          String    @id @default(uuid())
  name        String    @unique
  logoUrl     String?
  
  products    Product[]
}

// -----------------------------------------------------------------------------
// INVENTORY & WAREHOUSES
// -----------------------------------------------------------------------------

model Warehouse {
  id          String    @id @default(uuid())
  name        String
  location    String?
  isDefault   Boolean   @default(false)
  
  inventories Inventory[]
}

model Inventory {
  id          String    @id @default(uuid())
  
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  
  quantity    Int       @default(0)
  batchNumber String?
  expiryDate  DateTime?
  
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId, batchNumber])
}

// -----------------------------------------------------------------------------
// SALES & TRANSACTIONS
// -----------------------------------------------------------------------------

model Customer {
  id            String    @id @default(uuid())
  name          String
  email         String?
  phone         String?   @unique
  address       String?
  loyaltyPoints Int       @default(0)
  walletBalance Decimal   @default(0) @db.Decimal(10, 2)
  
  createdAt     DateTime  @default(now())
  
  sales         Sale[]
}

model Sale {
  id            String    @id @default(uuid())
  invoiceNo     String    @unique
  
  cashierId     String
  cashier       User      @relation("CashierSales", fields: [cashierId], references: [id])
  
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  
  subTotal      Decimal   @db.Decimal(12, 2)
  taxAmount     Decimal   @db.Decimal(12, 2)
  discount      Decimal   @db.Decimal(12, 2)
  total         Decimal   @db.Decimal(12, 2)
  
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus
  status        SaleStatus @default(COMPLETED)
  
  createdAt     DateTime  @default(now())
  
  items         SaleItem[]
  transactions  Transaction[]
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_BANKING
  WALLET
  SPLIT
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum SaleStatus {
  COMPLETED
  HELD
  SUSPENDED
  RETURNED
}

model SaleItem {
  id          String    @id @default(uuid())
  
  saleId      String
  sale        Sale      @relation(fields: [saleId], references: [id])
  
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  
  quantity    Int
  unitPrice   Decimal   @db.Decimal(10, 2)
  subTotal    Decimal   @db.Decimal(10, 2)
  tax         Decimal   @db.Decimal(10, 2)
  discount    Decimal   @db.Decimal(10, 2)
  total       Decimal   @db.Decimal(10, 2)
}

// -----------------------------------------------------------------------------
// PURCHASES & SUPPLIERS
// -----------------------------------------------------------------------------

model Supplier {
  id          String    @id @default(uuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  
  balanceDue  Decimal   @default(0) @db.Decimal(12, 2)
  
  purchases   Purchase[]
}

model Purchase {
  id          String    @id @default(uuid())
  referenceNo String    @unique
  
  supplierId  String
  supplier    Supplier  @relation(fields: [supplierId], references: [id])
  
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  
  totalAmount Decimal   @db.Decimal(12, 2)
  status      PurchaseStatus @default(PENDING)
  
  createdAt   DateTime  @default(now())
  
  items       PurchaseItem[]
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  PARTIAL
}

model PurchaseItem {
  id          String    @id @default(uuid())
  
  purchaseId  String
  purchase    Purchase  @relation(fields: [purchaseId], references: [id])
  
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  
  quantity    Int
  unitCost    Decimal   @db.Decimal(10, 2)
  totalCost   Decimal   @db.Decimal(10, 2)
}

// -----------------------------------------------------------------------------
// ACCOUNTING & AUDIT
// -----------------------------------------------------------------------------

model Transaction {
  id          String    @id @default(uuid())
  type        TransactionType
  amount      Decimal   @db.Decimal(12, 2)
  description String?
  
  saleId      String?
  sale        Sale?     @relation(fields: [saleId], references: [id])
  
  createdAt   DateTime  @default(now())
}

enum TransactionType {
  INCOME
  EXPENSE
  REFUND
}

model AuditLog {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  action      String    // "CREATE", "UPDATE", "DELETE", "LOGIN"
  entity      String    // "Product", "Sale", etc.
  entityId    String?
  details     Json?
  
  createdAt   DateTime  @default(now())
}
